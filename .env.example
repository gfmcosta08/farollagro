# FarollAgro Environment Variables
# Copy this file to .env and fill in your values

# Database
DB_USER=farollagro
DB_PASSWORD=your_secure_password_here_change_in_production
DB_NAME=farollagro

# JWT Secret (generate a strong random string for production)
JWT_SECRET=change-this-to-a-very-long-random-secret-key-in-production
JWT_EXPIRES_IN=7d

# Application
NODE_ENV=production
PORT=3000
CLIENT_URL=https://your-domain.com

# Redis (if using)
REDIS_URL=redis://localhost:6379
